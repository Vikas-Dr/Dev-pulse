generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String
  createdAt DateTime  @default(now())
  projects  Project[]
}

model Project {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  name        String
  path        String
  techStack   String   @default("unknown")
  addedAt     DateTime @default(now())
  lastScanned DateTime?
  gitStatus   String?
  lastCommit  DateTime?
  healthScore Float?
  githubRepo  String?
  scans       Scan[]
  patches     Patch[]
}

model Scan {
  id            String          @id @default(uuid())
  projectId     String
  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scannedAt     DateTime        @default(now())
  totalDeps     Int             @default(0)
  vulnerabilities Vulnerability[]
}

model Vulnerability {
  id              String @id @default(uuid())
  scanId          String
  scan            Scan   @relation(fields: [scanId], references: [id], onDelete: Cascade)
  packageName     String
  currentVersion  String
  severity        String
  title           String
  cve             String?
  fixedIn         String?
}

model Patch {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  patchedAt   DateTime @default(now())
  packageName String
  fromVersion String
  toVersion   String
  status      String
  output      String?
}
